NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only variables. Never expose these in browser code and never prefix
# them with NEXT_PUBLIC.
ADMIN_IMPORT_TOKEN=your-internal-import-token
SUPABASE_SERVICE_ROLE_KEY=your-local-seed-service-role-key
